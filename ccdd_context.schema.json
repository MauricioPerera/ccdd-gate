{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ccdd.dev/schemas/context-0.3.json",
  "title": "CCDD Context Contract",
  "description": "Esquema formal del context.yaml — CCDD v0.3 (§3 de la especificación).",
  "type": "object",
  "required": ["ccdd_version", "contract"],
  "additionalProperties": false,
  "properties": {
    "ccdd_version": {
      "type": "string",
      "description": "Versión del estándar CCDD al que se conforma el contrato.",
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
    },
    "contract": {
      "type": "object",
      "required": ["name", "budget", "slots"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "budget": {
          "type": "object",
          "required": ["model", "max_tokens"],
          "additionalProperties": false,
          "properties": {
            "model": { "type": "string", "minLength": 1 },
            "max_tokens": { "type": "integer", "exclusiveMinimum": 0 },
            "reserve_output": { "type": "integer", "minimum": 0, "default": 0 }
          }
        },
        "slots": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/slot" }
        },
        "guardrails": {
          "type": "array",
          "items": { "$ref": "#/$defs/guardrail" },
          "default": []
        }
      }
    }
  },
  "$defs": {
    "slot": {
      "type": "object",
      "required": ["id", "priority", "source", "compaction"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Identificador único del slot."
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "description": "Menor número = mayor prioridad de retención."
        },
        "source": { "$ref": "#/$defs/source" },
        "compaction": {
          "enum": ["none", "summarize", "truncate"],
          "description": "none = crítico (no se toca); summarize = heurístico/no-determinista; truncate = determinista."
        },
        "min_tokens": {
          "type": "integer",
          "minimum": 0,
          "description": "Piso duro; si el slot cae por debajo, el assemble aborta."
        },
        "max_tokens": { "type": "integer", "exclusiveMinimum": 0 },
        "review_quorum": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "Nº de revisores distintos que deben firmar un cambio de contenido de este slot (gate L2/R6). Default 1."
        }
      },
      "allOf": [
        {
          "$comment": "Un slot crítico (compaction: none) no debe tener min_tokens 0 implícito sin sentido; se recomienda min_tokens explícito pero no se exige aquí.",
          "if": {
            "properties": { "source": { "properties": { "type": { "const": "static" } } } }
          },
          "then": {
            "properties": {
              "source": { "required": ["path"] }
            }
          }
        }
      ]
    },
    "source": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "enum": ["static", "dynamic", "runtime"] },
        "path": {
          "type": "string",
          "description": "Ruta al archivo de contenido (solo type=static)."
        },
        "sign": {
          "type": "boolean",
          "default": false,
          "description": "Si true, el contenido se firma SHA-256 y se persiste en expected-hashes.json."
        },
        "provider": {
          "type": "string",
          "description": "Proveedor de datos (solo type=dynamic)."
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "static" } } },
          "then": { "required": ["path"] }
        }
      ]
    },
    "guardrail": {
      "type": "object",
      "required": ["id", "type", "on_fail"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "enum": ["regex_deny", "json_schema", "reference_check", "dsv_check"] },
        "on_fail": { "enum": ["abort", "reroute", "warn"] },
        "reroute_to": { "type": "string" },
        "target_slot": { "type": "string" },
        "pattern": { "type": "string" },
        "schema_path": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "on_fail": { "const": "reroute" } } },
          "then": { "required": ["reroute_to"] }
        },
        {
          "if": { "properties": { "type": { "const": "regex_deny" } } },
          "then": { "required": ["pattern"] }
        },
        {
          "if": { "properties": { "type": { "const": "json_schema" } } },
          "then": { "required": ["target_slot", "schema_path"] }
        },
        {
          "if": { "properties": { "type": { "const": "dsv_check" } } },
          "then": { "required": ["target_slot"] }
        }
      ]
    }
  }
}
