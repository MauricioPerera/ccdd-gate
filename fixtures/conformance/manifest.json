      "id": "simple",
      "target": "simple",
      "expected": {
        "cyclomatic": 1,
        "nesting_depth": 0,
        "parameter_count": 1,
        "function_length": 2
      },
      "language_overrides": {
        "typescript": {
          "function_length": 3
        },
        "rust": {
          "function_length": 3
        },
        "go": {
          "function_length": 3
        }
      },
      "note": "Función trivial: sin decisiones ni anidamiento.",
      "cross_language_divergence_allowed": [
        "function_length"
      ],
      "sources": {
        "python": "python/simple.py",
        "typescript": "typescript/simple.ts",
        "rust": "rust/simple.rs",
        "go": "go/simple.go"
      }
    },
